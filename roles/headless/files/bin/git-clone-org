#!/bin/bash

die() { echo "$*" >&2; exit 1; }

# Require an org to be specified
[ "$#" -eq 1 ] || die "Usage: git clone-org <org>"

# Optionally ignore any specified repos per env var
declare -p IGNORED_REPOS &>/dev/null || IGNORED_REPOS=()

# All we need is the org name to begin
ORG=${1}

# Ensure the org directory exists, and that we're in it
mkdir -p "${ORG}" || die "Failed to create directory: ${ORG}"
cd "${ORG}" || die "Failed to enter directory: ${ORG}"

echo "Fetching list of repos... (this may take awhile)"
REPOS=$(gh repo list ${ORG} --no-archived --json 'sshUrl,id,name,isArchived' --limit 1000)

# Iterate through each repo
idx=0
rep_count=$(echo $REPOS | jq 'length')
while read repo; do
    repo_name=$(jq -r '.name' <<< "$repo")
    idx=$((idx + 1))
    echo "$(date --iso-8601=seconds) PROGRESS: $idx / $repo_count"

    # Skip ignored repos
    skip_repo=false
    for ignored_repo_name in "${IGNORED_REPOS[@]}"; do
        if [ "$ignored_repo_name" = "$repo_name" ]; then
            skip_repo=true
            break
        fi
    done
    if [ "$skip_repo" = true ]; then
        echo "Skipping ignored repo: ${repo_name}"
        continue
    fi

    repo_url=$(jq -r '.sshUrl' <<< "${repo}")

    # check if the submodule already exists
    if [ -d "${repo_name}" ]; then
        echo "Updating ${repo_name}"
        cd "${repo_name}"
        git ready --no-branch
        cd ..
    else
        echo "Cloning ${repo_name}"
        git clone "${repo_url}" "${repo_name}"
        cd "${repo_name}"
        git ready --no-branch
        cd ..
    fi
done < <(echo $REPOS | jq -c '.[]')

echo "Fetching list of archived repos... (this may take awhile)"
REPOS=$(gh repo list ${ORG} --archived --json 'sshUrl,id,name,isArchived' --limit 1000)

# Iterate through each repo
idx=0
repo_count=$(echo $REPOS | jq 'length')
while read repo; do
    repo_name=$(jq -r '.name' <<< "$repo")
    idx=$((idx + 1))

    if jq -e '.isArchived == true' <<< "$repo" > /dev/null; then
        # Repo is archived
        if [ -n "${repo_name}" ] && [ -d "${repo_name}" ]; then
            # Repo exists locally and needs to be removed
            echo "Removing archived repo: ${repo_name}"
            rm -rf "${repo_name}"
        fi
    fi
done < <(echo $REPOS | jq -c '.[]')
